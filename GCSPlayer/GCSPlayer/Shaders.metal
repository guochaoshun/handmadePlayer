#include <metal_stdlib>
using namespace metal;

// 系统地介绍一下yuv和rgb的一些知识。为什么需要这个转换。
// 为什么编码的时候是yuv。而不能直接编码成rgb。这样不就不用做转换了吗?
// 如果可以的话,再介绍一下yuv和rgb的历史。
// -----------------------------------------------------------------------------
// 【灵魂拷问：关于 YUV 与 RGB 的底层思考】
// 问：系统地介绍一下yuv和rgb的一些知识。为什么需要这个转换？
//    为什么编码的时候是yuv，而不能直接编码成rgb？这样不就不用做转换了吗?
//    如果可以的话，再介绍一下yuv和rgb的历史。
//    假如说彻底抛开历史包袱，让你重新设计一套编码，你还会使用yuv吗？
//    为什么屏幕硬件只认rgb，它为什么不能改成认yuv呢？
// 
// [解答：YUV 与 RGB 的前世今生与底层逻辑]
//
// 1. 为什么编码压缩必须用 YUV，而坚决不用 RGB？（即使抛开历史包袱依然如此）
//    - 【数学与信息论原理】：RGB 三个通道的数据在自然界中是"高度相关"的（比如一面灰墙，R=G=B=128）。直接压缩 RGB 会导致极大的信息冗余。
//      YUV 的转换本质上是"去相关性"的数学魔法（K-L变换的近似），它将 90% 的能量集中在 Y（亮度）通道，使得 U、V（色差）通道能量极低，存在大量接近 0 的数据。
//      这种能量集中的特性，极其适合后续的 DCT 变换和哈夫曼编码进行极限压缩。
//    - 【生理学压缩（欺骗人眼）】：人眼的视网膜对"亮度(Y)"极其敏感，但对"色彩细节(U,V)"相对迟钝。
//      科学家利用这个生理漏洞，发明了色度子采样（如 YUV420）：保留 100% 的亮度(Y)，但每 4 个像素只共用 1 个 U 和 1 个 V。
//      结果：在还没开始真正的 H.264 算法压缩前，仅仅通过丢弃部分 UV，数据量就直接被物理砍半（3 bytes/px -> 1.5 bytes/px），且人眼几乎无法察觉画质受损。
//      (注：RGB 众生平等，无法进行这种"丢弃部分通道"的有损压缩，一旦丢弃画面颜色就会立刻崩坏。)
//    - 【优雅的可伸缩性】：YUV 天然分层。网速极差时，可以直接极大压缩 UV（牺牲色彩），但保留 Y（轮廓依然清晰）。
//    - 【历史包袱】：YUV 最初是为了让黑白电视机(只读Y)能兼容接收彩色电视(读YUV)信号而发明的，却意外成为了现代视频压缩的最优解。
//
// 2. 为什么显示器硬件只认 RGB，不能直接造一个 YUV 屏幕？
//    - 【物理发光限制】：屏幕（LCD/OLED）是发光设备。光学上的三原色就是红、绿、蓝，通过控制这三种灯管的电压（亮度）进行"加法混色"，可以合成自然界所有颜色。
//      但 YUV 是纯数学构造。Y(亮度)可以通过白光实现，但 U 和 V 是"色差"（相对值，且有负数），物理世界根本造不出能发射"蓝色差光"或"负的光"的灯管。
//    - 【生物学解剖限制】：人类的视网膜上有三种视锥细胞，分别对长波(偏红)、中波(偏绿)、短波(偏蓝)最敏感。
//      屏幕只需要点亮红绿蓝三个子像素，就能完美欺骗大脑合成出所有颜色。人类自带的就是"RGB 传感器"。
//
// 3. 软件与硬件的伟大分工与本文件的使命
//    - 传输/存储（软件世界）：使用 YUV 极限压缩数据。
//    - 发光/显示（物理世界）：必须使用 RGB 刺激人眼。
//    - 本文件 (Fragment Shader) 的使命：作为连接软硬件的桥梁，利用 GPU 恐怖的千万级并发计算能力，在渲染的最后一刻（耗时几乎为0），将数学压缩产物(YUV)瞬间翻译成物理发光指令(RGB)！
// -----------------------------------------------------------------------------

struct VertexOut {
    float4 position [[position]];
    float2 texCoord;
};

// 顶点着色器：直接根据 vertexID 生成全屏四边形的顶点和纹理坐标
vertex VertexOut vertexShader(uint vertexID [[vertex_id]]) {
    VertexOut out;
    // 0: (-1, -1), 1: (1, -1), 2: (-1, 1), 3: (1, 1)
    float2 positions[4] = {
        float2(-1.0, -1.0),
        float2( 1.0, -1.0),
        float2(-1.0,  1.0),
        float2( 1.0,  1.0)
    };
    // 0: (0, 1), 1: (1, 1), 2: (0, 0), 3: (1, 0)
    float2 texCoords[4] = {
        float2(0.0, 1.0),
        float2(1.0, 1.0),
        float2(0.0, 0.0),
        float2(1.0, 0.0)
    };
    
    out.position = float4(positions[vertexID], 0.0, 1.0);
    out.texCoord = texCoords[vertexID];
    return out;
}

// -----------------------------------------------------------------------------
// [渲染引擎] 片元着色器 (Fragment Shader)
// 作用：对屏幕上的每一个像素点进行并行计算，将 YUV 纹理采样并转换为 RGB 颜色。
// -----------------------------------------------------------------------------
fragment float4 fragmentShader(VertexOut in [[stage_in]],
                               texture2d<float> textureY [[texture(0)]],
                               texture2d<float> textureU [[texture(1)]],
                               texture2d<float> textureV [[texture(2)]]) {
    
    constexpr sampler texSampler(mag_filter::linear, min_filter::linear);
    
    // 1. 从三个单通道纹理中分别采样出 Y, U, V 的值
    // 在 Metal 的浮点数世界里，颜色的取值范围是 [0.0, 1.0]
    float y = textureY.sample(texSampler, in.texCoord).r;
    
    // 为什么要减去 0.5？
    // U 和 V 是色差信号，在数学上有正有负（比如偏蓝是正，偏黄是负）。
    // 但是计算机的 8 位字节 (UInt8) 只能存储 0~255。
    // 所以编码时，人为地把 0 点平移到了 128 (即浮点数里的 0.5)。
    // 这里减去 0.5，是为了把它们恢复成真实的、有正有负的色差值，才能参与后续的矩阵乘法。
    float u = textureU.sample(texSampler, in.texCoord).r - 0.5;
    float v = textureV.sample(texSampler, in.texCoord).r - 0.5;
    
    // 2. BT.601 颜色转换矩阵 (标清视频国际标准)
    // 这是科学家通过光谱微积分推导出来的固定常量，用于将 YUV 色彩空间映射回 RGB 色彩空间。
    float r = y + 1.402 * v;
    float g = y - 0.344 * u - 0.714 * v;
    float b = y + 1.772 * u;
    
    return float4(r, g, b, 1.0);
}
